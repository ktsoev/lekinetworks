# --- Remnawave (панель VPN) ---
PANEL_URL=https://panel.example.com
PANEL_TOKEN=
# Синтетический telegram id для сайта: BASE + users_site.id (целое >= BASE). Не менять после появления юзеров в панели.
SITE_PANEL_TELEGRAM_ID_BASE=8000000000000000

# --- MySQL ---
DB_USER=leki_vpn_user
DB_PASSWORD=
DB_NAME=leki_vpn_db
DATABASE_IP=127.0.0.1
DATABASE_PORT=3306

# --- Защита HTTP API (бот + /site); заголовок X-API-Key ---
SERVER_API_KEY=

# --- Сайт: JWT и OTP по почте ---
JWT_SECRET=
# Минуты (по умолчанию 7 дней = 10080)
JWT_EXPIRE_MINUTES=10080
OTP_EXPIRE_MINUTES=15

# --- SMTP (код входа на сайт) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=LEKI Networks
SMTP_TIMEOUT=60

# --- CORS для /site (через запятую, без пробелов или с пробелами — обрежутся) ---
SITE_CORS_ORIGINS=https://your-frontend.example.com

# --- Платежи: ЮKassa ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# За reverse proxy без доверенного IP ЮKassa: true / 1 / yes
YOOKASSA_SKIP_IP_CHECK=

# --- Платежи: CryptoBot ---
CRYPTOBOT_TOKEN=

# --- Платежи: 0xProcessing ---
OXP_MERCHANT_ID=
OXP_WEBHOOK_PASS=
# Тестовый режим ссылки оплаты: true / 1 / yes
OXP_TEST_PAYMENT=
